      "source": [
        "# Quick Translating Test\n",
        "\n",
        "from transformers import MBart50TokenizerFast, MBartForConditionalGeneration\n",
        "\n",
        "saved_tok   = MBart50TokenizerFast.from_pretrained(f'{DRIVE_PATH}/mbart_r2s')\n",
        "saved_model = MBartForConditionalGeneration.from_pretrained(f'{DRIVE_PATH}/mbart_r2s').to(device)\n",
        "saved_model.eval()\n",
        "\n",
        "def translate_saved(text):\n",
        "    saved_tok.src_lang='en_XX'\n",
        "    inputs=saved_tok(text,return_tensors='pt',max_length=128,truncation=True).to(device)\n",
        "    generated=saved_model.generate(\n",
        "        **inputs,\n",
        "        forced_bos_token_id=saved_tok.lang_code_to_id['en_XX'],\n",
        "        max_length=128,\n",
        "        num_beams=5,\n",
        "        early_stopping=True\n",
        "    )\n",
        "    return saved_tok.batch_decode(generated,skip_special_tokens=True)[0]\n",
        "\n",
        "for src,tgt in r2s_val[100:105]:\n",
        "    print(f'  Rural:    {src}')\n",
        "    print(f'  Expected: {tgt}')\n",
        "    print(f'  Got:      {translate_saved(src)}\\n')"
      ],
